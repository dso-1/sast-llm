# Database URLs
DATABASE_URL=
DATABASE_PRISMA_DATABASE_URL=
DATABASE_POSTGRES_URL=
# Session
IRON_SESSION_PASSWORD=complex_password_at_least_32_characters_long_for_security
# Cloudflare R2 Settings
# S3_API is the Public R2.dev URL (from R2 Dashboard -> Settings -> Public Access -> R2.dev subdomain)
S3_API=
# Cloudflare R2 API Tokens (from R2 Dashboard -> Manage R2 API Tokens)
# Note: Use the S3-compatible Access Key and Secret Key, NOT the Global API Token
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=go-reserve